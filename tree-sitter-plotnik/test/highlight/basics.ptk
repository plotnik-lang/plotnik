Q = (program (identifier) @id)
; <- @type
;   ^ @punctuation.bracket
;    ^ @tag
;                         ^ @label

Fn = (function_declaration name: (identifier) @name -body)
;                          ^ @property
;                                                   ^ @operator
;                                                    ^ @property

Pred = (identifier =~ /^get/) @fn :: Getter
;                  ^ @operator
;                     ^ @string.special
;                                 ^ @punctuation.delimiter
;                                    ^ @type

Text = (identifier) @text :: str
;                             ^ @type.builtin

Flag = (comment)? @present :: bool
;                             ^ @type.builtin

Missing = (statement_block (MISSING ";"))
;                           ^ @keyword
;                                   ^ @string
