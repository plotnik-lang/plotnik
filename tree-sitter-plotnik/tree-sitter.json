{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "plotnik",
      "camelcase": "Plotnik",
      "title": "Plotnik",
      "scope": "source.plotnik",
      "file-types": ["ptk"],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^(plotnik|ptk)$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "Apache-2.0",
    "description": "Plotnik query language grammar for tree-sitter",
    "authors": [
      {
        "name": "Sergei Zharinov"
      }
    ],
    "links": {
      "repository": "https://github.com/plotnik-lang/plotnik"
    }
  }
}
