[strings]
S0 "Beauty will save the world"
S1 "id"
S2 "outer"
S3 "Test"
S4 "program"
S5 "identifier"

[type_defs]
T0 = <Node>
T1 = Struct  M0:1  ; { id }
T2 = Struct  M1:1  ; { outer }
T3 = Optional(T0)  ; <Node>?
T4 = Optional(T1)  ; T1?

[type_members]
M0: S1 → T3  ; id: T3
M1: S2 → T4  ; outer: T4

[type_names]
N0: S3 → T2  ; Test

[entrypoints]
Test = 06 :: T2

