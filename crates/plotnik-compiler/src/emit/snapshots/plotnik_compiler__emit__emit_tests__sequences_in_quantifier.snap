[strings]
S0 "Beauty will save the world"
S1 "id"
S2 "num"
S3 "items"
S4 "Test"
S5 "array"
S6 "identifier"
S7 "number"

[type_defs]
T0 = <Node>
T1 = Struct  M0:2  ; { id, num }
T2 = ArrayStar(T1)  ; T1*
T3 = Struct  M2:1  ; { items }

[type_members]
M0: S1 → T0  ; id: <Node>
M1: S2 → T0  ; num: <Node>
M2: S3 → T2  ; items: T2

[type_names]
N0: S4 → T3  ; Test

[entrypoints]
Test = 06 :: T3

