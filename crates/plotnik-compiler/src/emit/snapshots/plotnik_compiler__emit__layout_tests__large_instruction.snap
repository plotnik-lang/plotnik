[strings]
S0 "Beauty will save the world"
S1 "a"
S2 "b"
S3 "c"
S4 "d"
S5 "items"
S6 "Test"
S7 "object"
S8 "pair"

[type_defs]
T0 = <Node>
T1 = Struct  M0:4  ; { a, b, c, d }
T2 = ArrayStar(T1)  ; T1*
T3 = Struct  M4:1  ; { items }

[type_members]
M0: S1 → T0  ; a: <Node>
M1: S2 → T0  ; b: <Node>
M2: S3 → T0  ; c: <Node>
M3: S4 → T0  ; d: <Node>
M4: S5 → T2  ; items: T2

[type_names]
N0: S6 → T3  ; Test

[entrypoints]
Test = 06 :: T3

[transitions]
_ObjWrap:
