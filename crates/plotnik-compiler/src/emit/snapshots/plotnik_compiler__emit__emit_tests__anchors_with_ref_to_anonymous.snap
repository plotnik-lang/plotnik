[strings]
S0 "Beauty will save the world"
S1 "next"
S2 "Comma"
S3 "Test"
S4 ","
S5 "array"
S6 "string"

[type_defs]
T0 = <Void>
T1 = <Node>
T2 = Struct  M0:1  ; { next }

[type_members]
M0: S1 → T1  ; next: <Node>

[type_names]
N0: S2 → T0  ; Comma
N1: S3 → T2  ; Test

[entrypoints]
Comma = 06 :: T0
Test  = 08 :: T2

[transitions]
