---
Test = (program {(identifier) @id}? @outer)
---
[strings]
S0 "Beauty will save the world"
S1 "id"
S2 "outer"
S3 "Test"
S4 "program"
S5 "identifier"

[type_defs]
T0 = <Node>
T1 = Struct  M0:1  ; { id }
T2 = Struct  M1:1  ; { outer }
T3 = Struct  M2:1  ; { id }
T4 = Optional(T0)  ; <Node>?
T5 = Optional(T1)  ; T1?

[type_members]
M0: S1 → T4  ; id: T4
M1: S2 → T5  ; outer: T5
M2: S1 → T0  ; id: <Node>

[type_names]
N0: S3 → T2  ; Test

[entrypoints]
Test = 06 :: T2

[transitions]
_ObjWrap:
  00  -ε-  [Obj]                            02
  02       Trampoline                       03
  03  -ε-  [EndObj]                         05
  05                                        ▶

Test:
  06   !   (program)                        08
  07  ...  
  08  -ε-  [Obj]                            22, 18
  10   !   (identifier) [Node Set(M0)]      12
  12  ─‣┘  [EndObj Set(M1)] _               14
  14                                        ▶
  15  ...  
  16  -ε-  [EndObj Set(M1)]                 14
  18  -ε-  [Null Set(M0)]                   16
  20  ─‣─  _                                10, 20
