T1 = Struct  M0:5  ; { a, b, c, d, e }
T2 = Optional(T0)  ; <Node>?

[type_members]
M0: S01 → T2  ; a: T2
M1: S02 → T2  ; b: T2
M2: S03 → T2  ; c: T2
M3: S04 → T2  ; d: T2
M4: S05 → T2  ; e: T2

[type_names]
N0: S06 → T1  ; Q

[entrypoints]
Q = 08 :: T1

